ENV_FILE=.env.live
ENVIRONMENT=live
TRADING_MODE=LIVE
LIVE_ORDERS_ENABLED=1
BINANCE_MYTRADES_ENABLED=1

QUOTE_ASSET=USDC
DEFAULT_SYMBOL=BTCUSDC
REGIME_SYMBOLS=BTCUSDC,ETHUSDC,SOLUSDC,BNBUSDC
SYMBOL=BTCUSDC
LIVE_MAX_NOTIONAL=25
SPOT_MODE=1

PANIC_DISABLE_TRADING=0

POSTGRES_USER=botuser
POSTGRES_PASSWORD=botpass
POSTGRES_DB=trading_live

DB_HOST=db
DB_PORT=5432
DB_NAME=trading_live
DB_USER=botuser
DB_PASS=botpass
DB_VOLUME_NAME=trading_live_db_data
DB_CONNECT_MAX_WAIT_SECONDS=60

# Binance - trade and read only
BINANCE_API_KEY=1234
BINANCE_API_SECRET=1234

# OpenAI
OPENAI_API_KEY=1234
OPENAI_MODEL=gpt-4.1-mini

# Regime
REGIME_ENABLED=1
REGIME_MODE=ENFORCE
REGIME_MAX_AGE_SECONDS=900
REGIME_LOOKBACK=200
REGIME_TREND_EMA_FAST=21
REGIME_TREND_EMA_SLOW=100
REGIME_VOL_ATR_PERIOD=14
REGIME_VOL_THRESHOLD_PCT=0.08
REGIME_SHOCK_Z=3.0
REGIME_TREND_MIN_STRENGTH_PCT=0.05
REGIME_INTERVALS=1m,5m
REGIME_SYMBOLS=BTCUSDC,ETHUSDC,SOLUSDC,BNBUSDC
REGIME_SLEEP_SECONDS=60

# Fees (live real fee pójdzie z filli, ale zostaw jako fallback)
PAPER_FEE_RATE=0.0004
PAPER_SLIPPAGE_RATE=0.0002

# Live UI
VITE_API_BASE_URL=/api
VITE_API_BASE_URL_LIVE=/api
VITE_API_BASE_URL_PAPER=/api

ALLOWED_ORIGINS=https://client1.trade.com,https://paper.client1.trade.com
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

INTERNAL_API_BASE=http://127.0.0.1:8001
AI_TUNE_INTERVAL_MINUTES=4320
AI_AUTO_APPLY=false
REGIME_SLEEP_SECONDS=60
VITE_QUOTE_ASSET=USDC

# automation-runner (DISABLE ONLY)
AUTOMATION_ENABLED=1
AUTOMATION_MODE=ACTIVE
AUTOMATION_TICK_SECONDS=60

IP_PANIC_WATCH_ENABLED=1
IPIFY_URL=https://api.ipify.org
IP_CHECK_INTERVAL_SECONDS=60

REGIME_WATCHDOG_ENABLED=1
REGIME_WATCH_INTERVAL_SECONDS=60
REGIME_LAG_MAX_1M_SECONDS=420
REGIME_LAG_MAX_5M_SECONDS=1200

DAILY_REPORT_ENABLED=1
DAILY_REPORT_HHMM_UTC=0020

ORC_ACTIONS_ENABLED=false
ORC_ALLOC_MAX_PICKS=8
ORC_ALLOC_HB_MAX_LAG_S=300
ORC_ALLOC_CANDLES_MAX_LAG_S=420
ORC_ALLOC_REGIME_LOOKBACK_MIN=30
ORC_ALLOC_HYSTERESIS_MIN=20
ORC_ALLOC_INTERVALS=1m,5m
ORC_ALLOC_A_ENABLED=0
ORC_ALLOC_MAX_PER_SYMBOL=1
# --- allocator safety ---
ORC_ALLOC_SYMBOL_EXPOSURE_CAP=50
ORC_ALLOC_COOLDOWN_HAS_OPEN_MIN=10
ORC_ALLOC_EXPOSURE_PRICE_SOURCE=LAST_CLOSE
ORC_V5_APPLY_ENABLED=1
ORC_V5_APPLY_INTERVAL_SECONDS=60

ALLOCATION_POLICY_NAME=default
ALLOCATOR_SOURCE=promoted

RSI_SOFT_EXIT_EXEC_MODE=STANDARD
RSI_SOFT_EXIT_MAKER_OFFSET_BPS=2
RSI_SOFT_EXIT_MAKER_TIMEOUT_SEC=7
RSI_SOFT_EXIT_MAKER_POLL_SEC=1
# Promotions -> Allocator (LIVE)
PROMO_ALLOC_ENABLED=0
PROMO_ALLOC_INTERVAL_SECONDS=60
PROMO_ALLOC_POLICY_NAME=default
PROMO_ALLOC_MIN_TRADES=5

SSOT_WATCHDOG_WINDOW_HOURS=48

INTERNAL_API_TOKEN=1234