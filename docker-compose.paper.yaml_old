services:
  db:
    image: postgres:16
    container_name: trading-db
    restart: always
    env_file: .env.paper
    environment:
      POSTGRES_USER: botuser
      POSTGRES_PASSWORD: botpass
      POSTGRES_DB: trading_paper
    volumes:
      - ./db_data:/var/lib/postgresql/data
    ports:
      - "5432:5432"

  bot-btc:
    build:
      context: .
      dockerfile: bot/Dockerfile
    container_name: trading-bot-worker-btc
    restart: always
    depends_on:
      - db
    env_file: .env.paper
    environment:
      SYMBOL: "BTCUSDC"
      STRATEGY_NAME: "RSI"
      REGIME_MODE: "ENFORCE"
      INTERVAL: "1m"
      QUOTE_ASSET: USDC
      DEFAULT_SYMBOL: BTCUSDC

  bot-eth:
    build: 
      context: .
      dockerfile: bot/Dockerfile
    container_name: trading-bot-worker-eth
    restart: always
    depends_on:
      - db
    env_file: .env.paper
    environment:
      SYMBOL: "ETHUSDC"
      STRATEGY_NAME: "RSI"
      REGIME_MODE: "ENFORCE"
      INTERVAL: "1m"
      QUOTE_ASSET: USDC
      DEFAULT_SYMBOL: ETHUSDC

  bot-sol:
    build: 
      context: .
      dockerfile: bot/Dockerfile
    container_name: trading-bot-worker-sol
    restart: always
    depends_on:
      - db
    env_file: .env.paper
    environment:
      SYMBOL: "SOLUSDC"
      STRATEGY_NAME: "RSI"
      REGIME_MODE: "ENFORCE"
      INTERVAL: "1m"
      QUOTE_ASSET: USDC
      DEFAULT_SYMBOL: SOLUSDC

  bot-bnb:
    build: 
      context: .
      dockerfile: bot/Dockerfile
    container_name: trading-bot-worker-bnb
    restart: always
    depends_on:
      - db
    env_file: .env.paper
    environment:
      SYMBOL: "BNBUSDC"
      STRATEGY_NAME: "RSI"
      REGIME_MODE: "ENFORCE"
      INTERVAL: "1m"
      QUOTE_ASSET: USDC
      DEFAULT_SYMBOL: BNBUSDC

  bot-trend-btc:
    build: 
      context: .
      dockerfile: bot_trend/Dockerfile
    container_name: trading-bot-trend-btc
    restart: always
    depends_on:
      - db
    env_file: .env.paper
    environment:
      SYMBOL: "BTCUSDC"
      INTERVAL: "1m"
      STRATEGY_NAME: "TREND"
      REGIME_MODE: "ENFORCE"
      QUOTE_ASSET: USDC
      DEFAULT_SYMBOL: BTCUSDC

  bot-trend-eth:
    build: 
      context: .
      dockerfile: bot_trend/Dockerfile
    container_name: trading-bot-trend-eth
    restart: always
    depends_on:
      - db
    env_file: .env.paper
    environment:
      SYMBOL: "ETHUSDC"
      INTERVAL: "1m"
      STRATEGY_NAME: "TREND"
      REGIME_MODE: "ENFORCE"
      QUOTE_ASSET: USDC
      DEFAULT_SYMBOL: ETHUSDC

  bot-trend-sol:
    build: 
      context: .
      dockerfile: bot_trend/Dockerfile
    container_name: trading-bot-trend-sol
    restart: always
    depends_on:
      - db
    env_file: .env.paper
    environment:
      SYMBOL: "SOLUSDC"
      INTERVAL: "1m"
      STRATEGY_NAME: "TREND"
      REGIME_MODE: "ENFORCE"
      QUOTE_ASSET: USDC
      DEFAULT_SYMBOL: SOLUSDC

  bot-trend-bnb:
    build: 
      context: .
      dockerfile: bot_trend/Dockerfile
    container_name: trading-bot-trend-bnb
    restart: always
    depends_on:
      - db
    env_file: .env.paper
    environment:
      SYMBOL: "BNBUSDC"
      INTERVAL: "1m"
      STRATEGY_NAME: "TREND"
      REGIME_MODE: "ENFORCE"
      QUOTE_ASSET: USDC
      DEFAULT_SYMBOL: BNBUSDC

  bot-bbrange-btc:
    build: 
      context: .
      dockerfile: bot_bbrange/Dockerfile
    container_name: trading-bot-bbrange-btc
    restart: always
    depends_on:
      - db
    env_file: .env.paper
    environment:
      SYMBOL: "BTCUSDC"
      STRATEGY_NAME: "BBRANGE"
      REGIME_MODE: "ENFORCE"
      RSI_PERIOD: "14"
      EMA_PERIOD: "21"
      BB_PERIOD: "20"
      BB_STD: "2.0"
      MIN_BB_WIDTH_PCT: "0.0025"
      RSI_LONG_MAX: "45"
      RSI_SHORT_MIN: "55"
      RSI_BLOCK_EXTREME_LOW: "10"
      RSI_BLOCK_EXTREME_HIGH: "90"
      QUOTE_ASSET: USDC
      DEFAULT_SYMBOL: BTCUSDC

  bot-bbrange-eth:
    build: 
      context: .
      dockerfile: bot_bbrange/Dockerfile
    container_name: trading-bot-bbrange-eth
    restart: always
    depends_on:
      - db
    env_file: .env.paper
    environment:
      SYMBOL: "ETHUSDC"
      STRATEGY_NAME: "BBRANGE"
      REGIME_MODE: "ENFORCE"
      RSI_PERIOD: "14"
      EMA_PERIOD: "21"
      BB_PERIOD: "20"
      BB_STD: "2.0"
      MIN_BB_WIDTH_PCT: "0.0020"
      RSI_LONG_MAX: "45"
      RSI_SHORT_MIN: "55"
      RSI_BLOCK_EXTREME_LOW: "10"
      RSI_BLOCK_EXTREME_HIGH: "90"
      QUOTE_ASSET: USDC
      DEFAULT_SYMBOL: ETHUSDC

  bot-bbrange-sol:
    build: 
      context: .
      dockerfile: bot_bbrange/Dockerfile
    container_name: trading-bot-bbrange-sol
    restart: always
    depends_on:
      - db
    env_file: .env.paper
    environment:
      SYMBOL: "SOLUSDC"
      STRATEGY_NAME: "BBRANGE"
      REGIME_MODE: "ENFORCE"
      RSI_PERIOD: "14"
      EMA_PERIOD: "21"
      BB_PERIOD: "20"
      BB_STD: "2.0"
      MIN_BB_WIDTH_PCT: "0.0030"
      RSI_LONG_MAX: "40"
      RSI_SHORT_MIN: "60"
      RSI_BLOCK_EXTREME_LOW: "10"
      RSI_BLOCK_EXTREME_HIGH: "90"
      QUOTE_ASSET: USDC
      DEFAULT_SYMBOL: SOLUSDC

  bot-bbrange-bnb:
    build: 
      context: .
      dockerfile: bot_bbrange/Dockerfile
    container_name: trading-bot-bbrange-bnb
    restart: always
    depends_on:
      - db
    env_file: .env.paper
    environment:
      SYMBOL: "BNBUSDC"
      STRATEGY_NAME: "BBRANGE"
      REGIME_MODE: "ENFORCE"
      RSI_PERIOD: "14"
      EMA_PERIOD: "21"
      BB_PERIOD: "20"
      BB_STD: "2.0"
      MIN_BB_WIDTH_PCT: "0.0025"
      RSI_LONG_MAX: "45"
      RSI_SHORT_MIN: "60"
      RSI_BLOCK_EXTREME_LOW: "10"
      RSI_BLOCK_EXTREME_HIGH: "90"
      QUOTE_ASSET: USDC
      DEFAULT_SYMBOL: BNBUSDC

  bot-st-btc:
    build: 
      context: .
      dockerfile: bot_supertrend/Dockerfile
    container_name: trading-bot-supertrend-btc
    restart: always
    depends_on:
      - db
    env_file: .env.paper
    environment:
      SYMBOL: "BTCUSDC"
      STRATEGY_NAME: "SUPER_TREND"
      REGIME_MODE: "ENFORCE"
      INTERVAL: "1m"
      ATR_PERIOD: "14"
      ST_MULTIPLIER: "3.0"
      ORDER_QTY_BTC: "0.0001"
      QUOTE_ASSET: USDC
      DEFAULT_SYMBOL: BTCUSDC

  bot-st-eth:
    build: 
      context: .
      dockerfile: bot_supertrend/Dockerfile
    container_name: trading-bot-supertrend-eth
    restart: always
    depends_on:
      - db
    env_file: .env.paper
    environment:
      SYMBOL: "ETHUSDC"
      STRATEGY_NAME: "SUPER_TREND"
      REGIME_MODE: "ENFORCE"
      INTERVAL: "1m"
      ATR_PERIOD: "14"
      ST_MULTIPLIER: "3.0"
      ORDER_QTY_BTC: "0.0001"
      QUOTE_ASSET: USDC
      DEFAULT_SYMBOL: ETHUSDC

  bot-st-sol:
    build: 
      context: .
      dockerfile: bot_supertrend/Dockerfile
    container_name: trading-bot-supertrend-sol
    restart: always
    depends_on:
      - db
    env_file: .env.paper
    environment:
      SYMBOL: "SOLUSDC"
      STRATEGY_NAME: "SUPER_TREND"
      REGIME_MODE: "ENFORCE"
      INTERVAL: "1m"
      ATR_PERIOD: "14"
      ST_MULTIPLIER: "3.0"
      ORDER_QTY_BTC: "0.0001"
      QUOTE_ASSET: USDC
      DEFAULT_SYMBOL: SOLUSDC

  bot-st-bnb:
    build: 
      context: .
      dockerfile: bot_supertrend/Dockerfile
    container_name: trading-bot-supertrend-bnb
    restart: always
    depends_on:
      - db
    env_file: .env.paper
    environment:
      SYMBOL: "BNBUSDC"
      STRATEGY_NAME: "SUPER_TREND"
      REGIME_MODE: "ENFORCE"
      INTERVAL: "1m"
      ATR_PERIOD: "14"
      ST_MULTIPLIER: "3.0"
      ORDER_QTY_BTC: "0.0001"
      QUOTE_ASSET: USDC
      DEFAULT_SYMBOL: BNBUSDC

  api:
    build: ./api
    container_name: trading-api
    restart: always
    depends_on:
      - db
    env_file: .env.paper
    environment:
      AI_TUNE_INTERVAL_MINUTES: "4320"
      AI_AUTO_APPLY: "false"
      INTERNAL_API_BASE: "http://127.0.0.1:8000"
      OPENAI_MODEL: "gpt-4.1-mini"
      QUOTE_ASSET: USDC
      DEFAULT_SYMBOL: BTCUSDC
    ports:
      - "8000:8000"

  frontend:
    build:
      context: ./frontend
    container_name: trading-frontend
    restart: always
    ports:
      - "3000:80"
    depends_on:
      - api
    environment:
      VITE_API_BASE_URL: "http://192.168.101.10:8000"
      VITE_QUOTE_ASSET: "USDC"

  regime-worker:
    build:
      context: .
      dockerfile: regime_worker/Dockerfile
    container_name: trading-regime-worker
    restart: always
    depends_on:
      - db
    env_file: .env.paper
    environment:
      REGIME_SYMBOLS: "BTCUSDC,ETHUSDC,SOLUSDC,BNBUSDC"
      REGIME_INTERVAL: "1m"
      REGIME_SLEEP_SECONDS: "60"
      REGIME_LOOKBACK: "${REGIME_LOOKBACK:-200}"
      REGIME_TREND_EMA_FAST: "${REGIME_TREND_EMA_FAST:-21}"
      REGIME_TREND_EMA_SLOW: "${REGIME_TREND_EMA_SLOW:-100}"
      REGIME_VOL_ATR_PERIOD: "${REGIME_VOL_ATR_PERIOD:-14}"
      REGIME_VOL_THRESHOLD_PCT: "${REGIME_VOL_THRESHOLD_PCT:-0.08}"
      REGIME_SHOCK_Z: "${REGIME_SHOCK_Z:-3.0}"
      REGIME_TREND_MIN_STRENGTH_PCT: "${REGIME_TREND_MIN_STRENGTH_PCT:-0.05}"
      QUOTE_ASSET: USDC
      DEFAULT_SYMBOL: BTCUSDC