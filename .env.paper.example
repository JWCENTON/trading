ENV_FILE=.env.paper
ENVIRONMENT=paper
TRADING_MODE=PAPER
LIVE_ORDERS_ENABLED=0
QUOTE_ASSET=USDC
DEFAULT_SYMBOL=BTCUSDC
BINANCE_MYTRADES_ENABLED=0

# public hosts
PUBLIC_LIVE_HOST=client0.example.com
PUBLIC_PAPER_HOST=paper.client0.example.com

POSTGRES_USER=botuser
POSTGRES_PASSWORD=botpass
POSTGRES_DB=trading_paper

DB_HOST=db
DB_PORT=5432
DB_NAME=trading_paper
DB_USER=botuser
DB_PASS=1234
DB_VOLUME_NAME=trading_paper_db_data
DB_CONNECT_MAX_WAIT_SECONDS=60

# Binance
BINANCE_API_KEY=123
BINANCE_API_SECRET=123

# OpenAI
OPENAI_API_KEY=1234
OPENAI_MODEL=gpt-4.1-mini

# Regime
REGIME_ENABLED=1
REGIME_MODE=DRY_RUN
REGIME_MAX_AGE_SECONDS=900
REGIME_LOOKBACK=200
REGIME_TREND_EMA_FAST=21
REGIME_TREND_EMA_SLOW=100
REGIME_VOL_ATR_PERIOD=14
REGIME_VOL_THRESHOLD_PCT=0.08
REGIME_SHOCK_Z=3.0
REGIME_TREND_MIN_STRENGTH_PCT=0.05
REGIME_INTERVALS=1m,5m
REGIME_SYMBOLS=BTCUSDC,ETHUSDC,SOLUSDC,BNBUSDC
REGIME_SLEEP_SECONDS=60

# Fees
PAPER_FEE_RATE=0.0004
PAPER_SLIPPAGE_RATE=0.0002

# Paper UI
VITE_API_BASE_URL=/api

INTERNAL_API_BASE=http://127.0.0.1:8000
AI_TUNE_INTERVAL_MINUTES=4320
AI_AUTO_APPLY=false
VITE_QUOTE_ASSET=USDC
VITE_API_BASE_URL_LIVE=/api
VITE_API_BASE_URL_PAPER=/api

# paper -> live bridge
LIVE_API_BASE=http://192.168.101.10/api

# cors
ALLOWED_ORIGINS=http://192.168.101.10,http://192.168.101.10

# auth/session
SESSION_COOKIE_NAME=trading_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# automation-runner (DISABLE ONLY)
AUTOMATION_ENABLED=1
AUTOMATION_MODE=DISABLE_ONLY
AUTOMATION_TICK_SECONDS=60

IP_PANIC_WATCH_ENABLED=1
IPIFY_URL=https://api.ipify.org
IP_CHECK_INTERVAL_SECONDS=60

REGIME_WATCHDOG_ENABLED=1
REGIME_WATCH_INTERVAL_SECONDS=60
REGIME_LAG_MAX_1M_SECONDS=420
REGIME_LAG_MAX_5M_SECONDS=1200

DAILY_REPORT_ENABLED=1
DAILY_REPORT_HHMM_UTC=0020

ORC_ACTIONS_ENABLED=false

# Promotions publisher (PAPER -> LIVE)
PROMOTIONS_ENABLED=1
PROMOTIONS_INTERVAL_SECONDS=300
PROMOTIONS_TOP_K=20
PROMOTIONS_WINDOW_NAME=10d
PROMOTIONS_POLICY_VERSION=paper_rank_v2
PROMOTIONS_MIN_TRADES=5

SSOT_WATCHDOG_WINDOW_HOURS=48

INTERNAL_API_TOKEN=1234

# app
APP_BASE_URL=http://192.168.101.10