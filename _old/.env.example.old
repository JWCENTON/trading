ENVIRONMENT=paper
TRADING_MODE=PAPER

POSTGRES_USER=botuser
POSTGRES_PASSWORD=botpass
POSTGRES_DB=trading_paper

DB_HOST=db
DB_PORT=5432
DB_NAME=trading_paper
DB_USER=botuser
DB_PASS=botpass

# Binance
BINANCE_API_KEY=<BINANCE_API_KEY>
BINANCE_API_SECRET=<BINANCE_API_SECRET>

# OpenAI
OPENAI_API_KEY=<OPENAI_API_KEY>
OPENAI_MODEL=gpt-4.1-mini

# Regime
REGIME_ENABLED=1
REGIME_MODE=DRY_RUN
REGIME_MAX_AGE_SECONDS=180
REGIME_LOOKBACK=200
REGIME_TREND_EMA_FAST=21
REGIME_TREND_EMA_SLOW=100
REGIME_VOL_ATR_PERIOD=14
REGIME_VOL_THRESHOLD_PCT=0.08
REGIME_SHOCK_Z=3.0
REGIME_TREND_MIN_STRENGTH_PCT=0.05

# Fees
PAPER_FEE_RATE=0.0004
PAPER_SLIPPAGE_RATE=0.0002