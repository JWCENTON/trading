services:
  db:
    image: postgres:16
    container_name: trading-db
    restart: always
    env_file: .env
    environment:
      POSTGRES_USER: ${POSTGRES_USER}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      POSTGRES_DB: ${POSTGRES_DB}
    volumes:
      - ./db_data:/var/lib/postgresql/data
    ports:
      - "5432:5432"

  db_live:
    image: postgres:16
    container_name: trading-db-live
    restart: always
    env_file: .env.live
    environment:
      POSTGRES_USER: ${POSTGRES_USER}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      POSTGRES_DB: ${POSTGRES_DB}
    volumes:
      - ./db_live_data:/var/lib/postgresql/data
    ports:
      - "5433:5432"

  bot-btc:
    build:
      context: .
      dockerfile: bot/Dockerfile
    container_name: trading-bot-worker-btc
    restart: always
    depends_on:
      - db
    env_file: .env
    environment:
      SYMBOL: "BTCUSDT"
      STRATEGY_NAME: "RSI"
      REGIME_MODE: "ENFORCE"
      INTERVAL: "1m"
      RSI_OVERSOLD: "18"
      RSI_OVERBOUGHT: "82"
      TREND_BUFFER: "0.001"
      STOP_LOSS_PCT: "0.8"
      TAKE_PROFIT_PCT: "1.8"
      MAX_POSITION_MINUTES: "60"
      DAILY_MAX_LOSS_PCT: "0.5"
      DISABLE_HOURS: "7,17"
      PAPER_START_USDT: "100"

  bot-eth:
    build: 
      context: .
      dockerfile: bot/Dockerfile
    container_name: trading-bot-worker-eth
    restart: always
    depends_on:
      - db
    env_file: .env
    environment:
      SYMBOL: "ETHUSDT"
      STRATEGY_NAME: "RSI"
      REGIME_MODE: "ENFORCE"
      INTERVAL: "1m"
      RSI_OVERSOLD: "15"
      RSI_OVERBOUGHT: "85"
      TREND_BUFFER: "0.001"
      STOP_LOSS_PCT: "0.9"
      TAKE_PROFIT_PCT: "1.8"
      MAX_POSITION_MINUTES: "45"
      DAILY_MAX_LOSS_PCT: "0.5"
      PAPER_START_USDT: "100"

  bot-sol:
    build: 
      context: .
      dockerfile: bot/Dockerfile
    container_name: trading-bot-worker-sol
    restart: always
    depends_on:
      - db
    env_file: .env
    environment:
      SYMBOL: "SOLUSDT"
      STRATEGY_NAME: "RSI"
      REGIME_MODE: "ENFORCE"
      INTERVAL: "1m"
      RSI_OVERSOLD: "22"
      RSI_OVERBOUGHT: "78"
      TREND_BUFFER: "0.001"
      STOP_LOSS_PCT: "0.8"
      TAKE_PROFIT_PCT: "1.6"
      MAX_POSITION_MINUTES: "60"
      DAILY_MAX_LOSS_PCT: "0.5"
      PAPER_START_USDT: "100"

  bot-bnb:
    build: 
      context: .
      dockerfile: bot/Dockerfile
    container_name: trading-bot-worker-bnb
    restart: always
    depends_on:
      - db
    env_file: .env
    environment:
      SYMBOL: "BNBUSDT"
      STRATEGY_NAME: "RSI"
      REGIME_MODE: "ENFORCE"
      INTERVAL: "1m"
      RSI_OVERSOLD: "22"
      RSI_OVERBOUGHT: "78"
      TREND_BUFFER: "0.001"
      STOP_LOSS_PCT: "0.8"
      TAKE_PROFIT_PCT: "1.6"
      MAX_POSITION_MINUTES: "60"
      DAILY_MAX_LOSS_PCT: "0.5"
      DISABLE_HOURS: "7,17"
      PAPER_START_USDT: "100"

  bot-trend-btc:
    build: 
      context: .
      dockerfile: bot_trend/Dockerfile
    container_name: trading-bot-trend-btc
    restart: always
    depends_on:
      - db
    env_file: .env
    environment:
      SYMBOL: "BTCUSDT"
      INTERVAL: "1m"
      STRATEGY_NAME: "TREND"
      PAPER_START_USDT: "100"
      REGIME_MODE: "ENFORCE"
      EMA_FAST: "21"
      EMA_SLOW: "50"
      ENTRY_BUFFER_PCT: "0.002"
      STOP_LOSS_PCT: "0.8"
      TAKE_PROFIT_PCT: "3.0"
      DAILY_MAX_LOSS_PCT: "0.5"
      MAX_POSITION_MINUTES: "30"

  bot-trend-eth:
    build: 
      context: .
      dockerfile: bot_trend/Dockerfile
    container_name: trading-bot-trend-eth
    restart: always
    depends_on:
      - db
    env_file: .env
    environment:
      SYMBOL: "ETHUSDT"
      INTERVAL: "1m"
      STRATEGY_NAME: "TREND"
      PAPER_START_USDT: "100"
      REGIME_MODE: "ENFORCE"
      EMA_FAST: "21"
      EMA_SLOW: "50"
      ENTRY_BUFFER_PCT: "0.002"
      STOP_LOSS_PCT: "0.6"
      TAKE_PROFIT_PCT: "2.0"
      DAILY_MAX_LOSS_PCT: "0.5"
      MAX_POSITION_MINUTES: "30"

  bot-trend-sol:
    build: 
      context: .
      dockerfile: bot_trend/Dockerfile
    container_name: trading-bot-trend-sol
    restart: always
    depends_on:
      - db
    env_file: .env
    environment:
      SYMBOL: "SOLUSDT"
      INTERVAL: "1m"
      STRATEGY_NAME: "TREND"
      PAPER_START_USDT: "100"
      REGIME_MODE: "ENFORCE"
      EMA_FAST: "21"
      EMA_SLOW: "50"
      ENTRY_BUFFER_PCT: "0.002"
      STOP_LOSS_PCT: "0.8"
      TAKE_PROFIT_PCT: "3.0"
      DAILY_MAX_LOSS_PCT: "0.5"
      MAX_POSITION_MINUTES: "30"

  bot-trend-bnb:
    build: 
      context: .
      dockerfile: bot_trend/Dockerfile
    container_name: trading-bot-trend-bnb
    restart: always
    depends_on:
      - db
    env_file: .env
    environment:
      SYMBOL: "BNBUSDT"
      INTERVAL: "1m"
      STRATEGY_NAME: "TREND"
      PAPER_START_USDT: "100"
      REGIME_MODE: "ENFORCE"
      EMA_FAST: "21"
      EMA_SLOW: "50"
      ENTRY_BUFFER_PCT: "0.002"
      STOP_LOSS_PCT: "0.6"
      TAKE_PROFIT_PCT: "2.0"
      DAILY_MAX_LOSS_PCT: "0.5"
      MAX_POSITION_MINUTES: "30"

  trading-bot-bbrange-btc:
    build: 
      context: .
      dockerfile: bot_bbrange/Dockerfile
    container_name: trading-bot-bbrange-btc
    restart: always
    depends_on:
      - db
    env_file: .env
    environment:
      SYMBOL: "BTCUSDT"
      STRATEGY_NAME: "BBRANGE"
      REGIME_MODE: "ENFORCE"
      RSI_PERIOD: "14"
      EMA_PERIOD: "21"
      STOP_LOSS_PCT: "0.4"
      TAKE_PROFIT_PCT: "0.9"
      TREND_BUFFER: "0.001"
      MAX_POSITION_MINUTES: "60"
      DAILY_MAX_LOSS_PCT: "0.5"
      BB_PERIOD: "20"
      BB_STD: "2.0"
      MIN_BB_WIDTH_PCT: "0.0025"
      RSI_LONG_MAX: "45"
      RSI_SHORT_MIN: "55"
      RSI_BLOCK_EXTREME_LOW: "10"
      RSI_BLOCK_EXTREME_HIGH: "90"

  trading-bot-bbrange-eth:
    build: 
      context: .
      dockerfile: bot_bbrange/Dockerfile
    container_name: trading-bot-bbrange-eth
    restart: always
    depends_on:
      - db
    env_file: .env
    environment:
      SYMBOL: "ETHUSDT"
      STRATEGY_NAME: "BBRANGE"
      REGIME_MODE: "ENFORCE"
      RSI_PERIOD: "14"
      EMA_PERIOD: "21"
      STOP_LOSS_PCT: "0.5"
      TAKE_PROFIT_PCT: "0.85"
      TREND_BUFFER: "0.001"
      MAX_POSITION_MINUTES: "60"
      DAILY_MAX_LOSS_PCT: "0.5"
      BB_PERIOD: "20"
      BB_STD: "2.0"
      MIN_BB_WIDTH_PCT: "0.0020"
      RSI_LONG_MAX: "45"
      RSI_SHORT_MIN: "55"
      RSI_BLOCK_EXTREME_LOW: "10"
      RSI_BLOCK_EXTREME_HIGH: "90"

  trading-bot-bbrange-sol:
    build: 
      context: .
      dockerfile: bot_bbrange/Dockerfile
    container_name: trading-bot-bbrange-sol
    restart: always
    depends_on:
      - db
    env_file: .env
    environment:
      SYMBOL: "SOLUSDT"
      STRATEGY_NAME: "BBRANGE"
      REGIME_MODE: "ENFORCE"
      RSI_PERIOD: "14"
      EMA_PERIOD: "21"
      STOP_LOSS_PCT: "0.6"
      TAKE_PROFIT_PCT: "1.15"
      TREND_BUFFER: "0.001"
      MAX_POSITION_MINUTES: "25"
      DAILY_MAX_LOSS_PCT: "0.5"
      BB_PERIOD: "20"
      BB_STD: "2.0"
      MIN_BB_WIDTH_PCT: "0.0030"
      RSI_LONG_MAX: "40"
      RSI_SHORT_MIN: "60"
      RSI_BLOCK_EXTREME_LOW: "10"
      RSI_BLOCK_EXTREME_HIGH: "90"

  trading-bot-bbrange-bnb:
    build: 
      context: .
      dockerfile: bot_bbrange/Dockerfile
    container_name: trading-bot-bbrange-bnb
    restart: always
    depends_on:
      - db
    env_file: .env
    environment:
      SYMBOL: "BNBUSDT"
      STRATEGY_NAME: "BBRANGE"
      REGIME_MODE: "ENFORCE"
      RSI_PERIOD: "14"
      EMA_PERIOD: "21"
      STOP_LOSS_PCT: "0.5"
      TAKE_PROFIT_PCT: "1.0"
      TREND_BUFFER: "0.001"
      MAX_POSITION_MINUTES: "60"
      DAILY_MAX_LOSS_PCT: "0.5"
      BB_PERIOD: "20"
      BB_STD: "2.0"
      MIN_BB_WIDTH_PCT: "0.0025"
      RSI_LONG_MAX: "45"
      RSI_SHORT_MIN: "60"
      RSI_BLOCK_EXTREME_LOW: "10"
      RSI_BLOCK_EXTREME_HIGH: "90"

  bot-st-btc:
    build: 
      context: .
      dockerfile: bot_supertrend/Dockerfile
    container_name: trading-bot-supertrend-btc
    restart: always
    depends_on:
      - db
    env_file: .env
    environment:
      SYMBOL: "BTCUSDT"
      STRATEGY_NAME: "SUPER_TREND"
      REGIME_MODE: "ENFORCE"
      INTERVAL: "1m"
      ATR_PERIOD: "14"
      ST_MULTIPLIER: "3.0"
      STOP_LOSS_PCT: "0.8"
      TAKE_PROFIT_PCT: "2.0"
      MAX_POSITION_MINUTES: "90"
      DAILY_MAX_LOSS_PCT: "0.5"
      PAPER_START_USDT: "100"
      # jeśli używasz workera z ORDER_QTY_BTC:
      ORDER_QTY_BTC: "0.0001"

  bot-st-eth:
    build: 
      context: .
      dockerfile: bot_supertrend/Dockerfile
    container_name: trading-bot-supertrend-eth
    restart: always
    depends_on:
      - db
    env_file: .env
    environment:
      SYMBOL: "ETHUSDT"
      STRATEGY_NAME: "SUPER_TREND"
      REGIME_MODE: "ENFORCE"
      INTERVAL: "1m"
      ATR_PERIOD: "14"
      ST_MULTIPLIER: "3.0"
      STOP_LOSS_PCT: "0.6"
      TAKE_PROFIT_PCT: "1.8"
      MAX_POSITION_MINUTES: "90"
      DAILY_MAX_LOSS_PCT: "0.5"
      PAPER_START_USDT: "100"
      ORDER_QTY_BTC: "0.0001"

  bot-st-sol:
    build: 
      context: .
      dockerfile: bot_supertrend/Dockerfile
    container_name: trading-bot-supertrend-sol
    restart: always
    depends_on:
      - db
    env_file: .env
    environment:
      SYMBOL: "SOLUSDT"
      STRATEGY_NAME: "SUPER_TREND"
      REGIME_MODE: "ENFORCE"
      INTERVAL: "1m"
      ATR_PERIOD: "14"
      ST_MULTIPLIER: "3.0"
      STOP_LOSS_PCT: "0.8"
      TAKE_PROFIT_PCT: "2.5"
      MAX_POSITION_MINUTES: "90"
      DAILY_MAX_LOSS_PCT: "0.5"
      PAPER_START_USDT: "100"
      ORDER_QTY_BTC: "0.0001"

  bot-st-bnb:
    build: 
      context: .
      dockerfile: bot_supertrend/Dockerfile
    container_name: trading-bot-supertrend-bnb
    restart: always
    depends_on:
      - db
    env_file: .env
    environment:
      SYMBOL: "BNBUSDT"
      STRATEGY_NAME: "SUPER_TREND"
      REGIME_MODE: "ENFORCE"
      INTERVAL: "1m"
      ATR_PERIOD: "14"
      ST_MULTIPLIER: "3.0"
      STOP_LOSS_PCT: "0.6"
      TAKE_PROFIT_PCT: "1.8"
      MAX_POSITION_MINUTES: "90"
      DAILY_MAX_LOSS_PCT: "0.5"
      PAPER_START_USDT: "100"
      ORDER_QTY_BTC: "0.0001"

  api:
    build: ./api
    container_name: trading-api
    restart: always
    depends_on:
      - db
    env_file: .env
    environment:
      PAPER_START_USDT: "100"
      AI_TUNE_INTERVAL_MINUTES: "1440"
      AI_AUTO_APPLY: "true"
      INTERNAL_API_BASE: "http://127.0.0.1:8000"
      OPENAI_MODEL: "gpt-4.1-mini"
    ports:
      - "8000:8000"


  frontend:
    build: ./frontend
    container_name: trading-frontend
    restart: always
    ports:
      - "3000:80"
    depends_on:
      - api

  regime-worker:
    build:
      context: .
      dockerfile: regime_worker/Dockerfile
    container_name: trading-regime-worker
    restart: always
    depends_on:
      - db
    env_file: .env
    environment:
      REGIME_SYMBOLS: "BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT"
      REGIME_INTERVAL: "1m"
      REGIME_SLEEP_SECONDS: "60"
      REGIME_LOOKBACK: "${REGIME_LOOKBACK:-200}"
      REGIME_TREND_EMA_FAST: "${REGIME_TREND_EMA_FAST:-21}"
      REGIME_TREND_EMA_SLOW: "${REGIME_TREND_EMA_SLOW:-100}"
      REGIME_VOL_ATR_PERIOD: "${REGIME_VOL_ATR_PERIOD:-14}"
      REGIME_VOL_THRESHOLD_PCT: "${REGIME_VOL_THRESHOLD_PCT:-0.08}"
      REGIME_SHOCK_Z: "${REGIME_SHOCK_Z:-3.0}"
      REGIME_TREND_MIN_STRENGTH_PCT: "${REGIME_TREND_MIN_STRENGTH_PCT:-0.05}"