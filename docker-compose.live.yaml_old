services:
  db_live:
    image: postgres:16
    restart: always
    env_file: .env.live
    environment:
      POSTGRES_USER: botuser
      POSTGRES_PASSWORD: botpass
      POSTGRES_DB: trading_live
    volumes:
      - trading_live_db_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U botuser -d trading_live"]
      interval: 5s
      timeout: 3s
      retries: 20

  api_live:
    build: ./api
    restart: always
    depends_on:
      db_live:
        condition: service_healthy
    env_file: .env.live
    environment:
      INTERNAL_API_BASE: "http://192.168.101.10:8001"
      AI_TUNE_INTERVAL_MINUTES: "4320"
      AI_AUTO_APPLY: "false"
      OPENAI_MODEL: "gpt-4.1-mini"
    ports:
      - "8001:8000"

  regime-worker_live:
    build:
      context: .
      dockerfile: regime_worker/Dockerfile
    restart: always
    depends_on:
      db_live:
        condition: service_healthy
    env_file: .env.live
    environment:
      QUOTE_ASSET: "USDC"
      REGIME_SYMBOLS: "BTCUSDC,ETHUSDC,SOLUSDC,BNBUSDC"
      REGIME_INTERVAL: "5m"
      REGIME_SLEEP_SECONDS: "60"
      REGIME_LOOKBACK: "200"
      REGIME_TREND_EMA_FAST: "21"
      REGIME_TREND_EMA_SLOW: "100"
      REGIME_VOL_ATR_PERIOD: "14"
      REGIME_VOL_THRESHOLD_PCT: "0.08"
      REGIME_SHOCK_Z: "3.0"
      REGIME_TREND_MIN_STRENGTH_PCT: "0.05"
  
  regime-worker_1m_live:
    build:
      context: .
      dockerfile: regime_worker/Dockerfile
    restart: always
    depends_on:
      db_live:
        condition: service_healthy
    env_file: .env.live
    environment:
      QUOTE_ASSET: "USDC"
      REGIME_SYMBOLS: "BTCUSDC,ETHUSDC,SOLUSDC,BNBUSDC"
      REGIME_INTERVAL: "1m"
      REGIME_SLEEP_SECONDS: "60"
      REGIME_LOOKBACK: "400"
      REGIME_TREND_EMA_FAST: "21"
      REGIME_TREND_EMA_SLOW: "100"
      REGIME_VOL_ATR_PERIOD: "14"
      REGIME_VOL_THRESHOLD_PCT: "0.08"
      REGIME_SHOCK_Z: "3.0"
      REGIME_TREND_MIN_STRENGTH_PCT: "0.05"

  frontend_live:
    build:
      context: ./frontend
    restart: always
    ports:
      - "3001:80"
    depends_on:
      - api_live
    environment:
      VITE_API_BASE_URL: "http://192.168.101.10:8001"
      VITE_QUOTE_ASSET: "USDC"

  bot-btc-live:
    build:
      context: .
      dockerfile: bot_trend/Dockerfile
    restart: always
    depends_on:
      db_live:
        condition: service_healthy
    env_file: .env.live
    environment:
      TRADING_MODE: "LIVE"
      LIVE_ORDERS_ENABLED: "1"
      REGIME_MODE: "ENFORCE"
      REGIME_MAX_AGE_SECONDS: "180"
      QUOTE_ASSET: "USDC"
      SYMBOL: "BTCUSDC"
      INTERVAL: "1m"
      STRATEGY_NAME: "TREND"

  bot-rsi-btc-live:
    build:
      context: .
      dockerfile: bot/Dockerfile
    restart: always
    depends_on:
      db_live:
        condition: service_healthy
    env_file: .env.live
    environment:
      TRADING_MODE: "LIVE"
      LIVE_ORDERS_ENABLED: "1"

      DB_HOST: "db_live"
      DB_NAME: "trading_live"
      DB_PORT: "5432"

      QUOTE_ASSET: "USDC"
      SYMBOL: "BTCUSDC"
      INTERVAL: "1m"
      STRATEGY_NAME: "RSI"
      REGIME_MODE: "ENFORCE"
      REGIME_MAX_AGE_SECONDS: "900"

  bot-bbrange-btc-live:
    build: 
      context: .
      dockerfile: bot_bbrange/Dockerfile
    restart: always
    depends_on:
      db_live:
        condition: service_healthy
    env_file: .env.live
    environment:
      TRADING_MODE: "LIVE"
      LIVE_ORDERS_ENABLED: "1"

      DB_HOST: "db_live"
      DB_NAME: "trading_live"
      DB_PORT: "5432"

      REGIME_MODE: "ENFORCE"
      REGIME_MAX_AGE_SECONDS: "900"
      QUOTE_ASSET: "USDC"
      SYMBOL: "BTCUSDC"
      INTERVAL: "1m"
      STRATEGY_NAME: "BBRANGE"

  bot-supertrend-btc-live:
    build:
      context: .
      dockerfile: bot_supertrend/Dockerfile
    restart: always
    depends_on:
      db_live:
        condition: service_healthy
    env_file: .env.live
    environment:
      TRADING_MODE: "LIVE"
      LIVE_ORDERS_ENABLED: "1"
      REGIME_MODE: "ENFORCE"
      REGIME_MAX_AGE_SECONDS: "180"
      QUOTE_ASSET: "USDC"
      SYMBOL: "BTCUSDC"
      INTERVAL: "1m"
      STRATEGY_NAME: "SUPERTREND"

volumes:
  trading_live_db_data: